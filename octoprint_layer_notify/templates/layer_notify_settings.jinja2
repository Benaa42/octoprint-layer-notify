<h4>Layer Notify</h4>
<p style="color:#888;font-size:12px;">Trigger notifications and GCODE commands when configured layers are reached.</p>

<h5>Target layers</h5>
<table class="table table-condensed table-bordered" style="margin-bottom:8px;">
    <thead>
        <tr>
            <th style="width:80px;">Layer</th>
            <th>GCODE Command <span style="font-weight:normal;color:#888;">(optional)</span></th>
            <th style="width:70px;text-align:center;">Active</th>
            <th style="width:90px;text-align:center;">Test</th>
            <th style="width:36px;"></th>
        </tr>
    </thead>
    <tbody data-bind="foreach: layerList">
        <tr>
            <td><input type="number" class="input-mini" min="1" step="1"
                       data-bind="value: layer" style="width:60px;"></td>
            <td><input type="text" class="input-medium"
                       data-bind="value: command" placeholder="e.g. M600"></td>
            <td style="text-align:center;vertical-align:middle;">
                <input type="checkbox" data-bind="checked: enabled">
            </td>
            <td style="text-align:center;vertical-align:middle;">
                <button class="btn btn-mini" data-bind="click: $root.testEntry">
                    <i class="fa fa-bell"></i>
                </button>
            </td>
            <td style="text-align:center;vertical-align:middle;">
                <button class="btn btn-mini btn-danger" data-bind="click: $root.removeLayer">
                    <i class="fa fa-trash"></i>
                </button>
            </td>
        </tr>
    </tbody>
</table>

<button class="btn btn-success btn-small" data-bind="click: addLayer">
    <i class="fa fa-plus"></i> Add layer
</button>

<hr style="margin:14px 0;">

<h5><i class="fa fa-volume-up"></i> Sound alert</h5>
<div class="form-horizontal">
    <div class="control-group">
        <label class="control-label">Sound enabled</label>
        <div class="controls" style="padding-top:4px;">
            <input type="checkbox"
                   data-bind="checked: settingsViewModel.settings.plugins.layer_notify.sound_enabled">
        </div>
    </div>
    <div class="control-group"
         data-bind="visible: settingsViewModel.settings.plugins.layer_notify.sound_enabled">
        <label class="control-label">Sound type</label>
        <div class="controls">
            <select class="input-medium"
                    data-bind="value: settingsViewModel.settings.plugins.layer_notify.sound_type">
                <option value="single">Single beep</option>
                <option value="triple">Triple beep</option>
                <option value="alarm">Alternating alarm</option>
                <option value="rising">Rising tone</option>
            </select>
            <button class="btn btn-mini" style="margin-left:6px;"
                    data-bind="click: previewSound">
                <i class="fa fa-volume-up"></i> Preview
            </button>
        </div>
    </div>
    <div class="control-group"
         data-bind="visible: settingsViewModel.settings.plugins.layer_notify.sound_enabled">
        <label class="control-label">Repeat</label>
        <div class="controls" style="display:flex;align-items:center;gap:8px;padding-top:4px;">
            <input type="number" min="1" max="10" class="input-mini"
                   data-bind="value: settingsViewModel.settings.plugins.layer_notify.sound_repeat"
                   style="width:55px;">
            <span style="color:#888;font-size:12px;">time(s)</span>
        </div>
    </div>
    <div class="control-group"
         data-bind="visible: settingsViewModel.settings.plugins.layer_notify.sound_enabled">
        <label class="control-label">Volume</label>
        <div class="controls" style="display:flex;align-items:center;gap:8px;padding-top:4px;">
            <input type="range" min="0" max="1" step="0.05" style="width:140px;"
                   data-bind="value: settingsViewModel.settings.plugins.layer_notify.sound_volume">
            <span style="color:#888;font-size:12px;min-width:36px;"
                  data-bind="text: Math.round(settingsViewModel.settings.plugins.layer_notify.sound_volume() * 100) + '%'">
            </span>
        </div>
    </div>
</div>

<hr style="margin:12px 0;">
<div style="background:#f9f9f9;border:1px solid #e0e0e0;border-radius:4px;padding:10px;font-size:12px;color:#666;">
    <strong>Supported slicers:</strong>
    Cura (<code>;LAYER:X</code>) &nbsp;&#183;&nbsp; PrusaSlicer (<code>; layer X,</code>) &nbsp;&#183;&nbsp; Any slicer (Z-move detection).<br>
    Each layer fires only once per print job.
</div>
